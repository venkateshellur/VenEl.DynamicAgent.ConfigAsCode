<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>VenEl.DynamicAgents.Core</PackageId>
    <Version>1.0.1</Version>
    <Authors>Venkatesh Ellur</Authors>
    <Title>VenEl.DynamicAgents.ConfigAsCode - Core</Title>
    <Description>Core abstractions, interfaces, and engine for VenEl.DynamicAgents.</Description>
    <RepositoryUrl>https://github.com/venkateshellur/VenEl.DynamicAgents</RepositoryUrl>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="YamlDotNet" Version="18.1.0" />
  </ItemGroup>

</Project>
